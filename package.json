{
  "name": "AutoProcure",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource/roboto": "^5.2.10",
    "@mui/material": "^5.18.0",
    "@parcel/optimizer-htmlnano": "^2.16.4",
    "@parcel/transformer-css": "^2.16.4",
    "@parcel/watcher": "^2.5.6",
    "@reduxjs/toolkit": "^2.11.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.19.15",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "axios": "^1.13.6",
    "dotenv": "^16.6.1",
    "lightningcss": "^1.31.1",
    "notistack": "^3.0.2",
    "parcel": "^2.16.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-redux": "^9.2.0",
    "react-router-dom": "^6.30.3",
    "react-scripts": "^5.0.1",
    "remixicon": "^4.9.1",
    "svgo": "^3.3.3",
    "typescript": "^4.9.5"
  },
  "scripts": {
    "start:backend": "python server/main.py",
    "start:frontend": "npm run clear && parcel public/index.html --dist-dir build --open chrome --port 3000",
    "start": "concurrently -c \"cyan,magenta\" -n \"REACT,FASTAPI\" \"npm run start:frontend\" \"npm run start:backend\"",
    "build": "npm run clear && parcel build public/index.html --dist-dir build",
    "test": "jest --clearMocks --no-cache --watchAll --coverage",
    "eject": "react-scripts eject",
    "clear": "rm -rf build .parcel-cache && npm run bundle",
    "bundle": "mkdir build && cp public/robots.txt build/"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@babel/preset-typescript": "^7.28.5",
    "@parcel/compressor-brotli": "^2.16.4",
    "@parcel/compressor-gzip": "^2.16.4",
    "@types/css-modules": "^1.0.5",
    "@types/jest": "^29.5.14",
    "concurrently": "^9.2.1",
    "gh-pages": "^6.3.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "process": "^0.11.10",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2"
  },
  "parcel-namer-rewrite": {
    "profiles": {
      "development": {
        "disable": true
      },
      "production": {
        "chain": "@parcel/namer-default",
        "rules": {
          "(.*).css$": "styles/$1{.hash}.css",
          "public(.*).json": "manifest{.hash}.json",
          "public(.*).xml": "browserconfig{.hash}.xml",
          "(.*).js$": "scripts/$1{.hash}.js",
          "(.*).png$": "assets/images/$1{.hash}.png",
          "(.*).webp$": "assets/images/$1{.hash}.webp",
          "(.*).jpg$": "assets/images/$1{.hash}.jpg",
          "(.*).jpeg$": "assets/images/$1{.hash}.jpeg",
          "(.*).svg$": "assets/images/$1{.hash}.svg",
          "(.*).gif$": "assets/images/$1{.hash}.gif",
          "(.*).avif$": "assets/images/$1{.hash}.avif",
          "version.html": "version.json"
        }
      }
    }
  },
  "@parcel/resolver-default": {
    "packageExports": true
  },
  "@parcel/transformer-css": {
    "cssModules": {
      "dashedIdents": true
    },
    "drafts": {
      "nesting": true,
      "customMedia": true
    }
  },
  "parcel": {
    "plugins": [
      "./parcel-plugin-dotenv.js"
    ]
  }
}
